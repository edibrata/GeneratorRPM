# Karena aplikasi ini di-deploy sebagai Web Statis (GitHub Pages), 
# API key harus tersedia di client-side menggunakan prefix VITE_
# PENTING: Untuk di GitHub Pages / Render Static Site, masukkan kunci rahasia ke environment variable dengan nama VITE_GEMINI_API_KEY
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
